{
  "$schema": "https://opencode.ai/config.json",

  "provider": {
    "copilot-api": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "copilot-api",
      "options": {
        "baseURL": "http://localhost:4141"
      },
      "models": {
        "gpt-4o": {
          "name": "GPT-4o"
        },
        "gpt-4": {
          "name": "GPT-4"
        }
      }
    }
  },
  "model":"gpt-4",
  "permission": {
    "skill": {
      "*": "allow"
    },
    "file": {
      "read": "allow",
      "write": "allow"
    },
    "shell": "allow"
  },
  "theme": "catppuccin-mocha",

  "lsp": {
    "pyright": {
      "disabled": true
    },
    "custom-python-lsp": {
      "command": ["python", ".opencode/lsp/custom_lsp_server.py"],
      "extensions": [".py"]
    }
  },

  "mcp": {
    "workspace-tools": {
      "type": "local",
      "command": ["python", ".opencode/mcp-servers/workspace-tools/server.py"],
      "enabled": true,
      "timeout": 30000
    }

  }
}
